# RestoreAssist Mobile — Environment Variables
# Copy this file to .env.local and fill in your values

# EAS Project ID — get from expo.dev after running: eas init
EAS_PROJECT_ID=

# App version (overrides app.config.js default)
APP_VERSION=1.0.0

# Build numbers (overridden by EAS autoIncrement in production)
ANDROID_VERSION_CODE=1
BUILD_NUMBER=1

# Supabase (same project as web app)
# For CI/CD, set these as EAS Secrets instead:
#   eas secret:create EXPO_PUBLIC_SUPABASE_URL --value "https://xxxx.supabase.co"
#   eas secret:create EXPO_PUBLIC_SUPABASE_ANON_KEY --value "eyJ..."
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Note: BYOK API keys are stored per-user in expo-secure-store (device keychain/keystore)
# They are NOT stored in environment variables — that is intentional (BYOK architecture)
