# RestoreAssist Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# DEVELOPMENT ONLY — local testing sign-in bypass
# Generate with: openssl rand -hex 8
# NEVER set this in production or staging environments
# ============================================
DEV_LOGIN_TOKEN=

# ============================================
# REQUIRED - Core Application
# ============================================

# Database (PostgreSQL with Prisma)
# Pooled connection via PgBouncer (use for queries)
# For Supabase: use port 6543 and append ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@localhost:5432/restoreassist"
# Direct connection (use for migrations)
# For Supabase: use port 5432 (direct, no pooler)
DIRECT_URL="postgresql://user:password@localhost:5432/restoreassist"

# ============================================
# SUPABASE STORAGE (RA-408)
# ============================================
# Supabase project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
# Supabase anonymous/public key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Supabase service role key — SERVER ONLY, never expose to browser
# Used for evidence upload pipeline (bypasses RLS to write to storage)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# RA-7031 (RA-1132i) — Live Teacher UI release flag. Defaults OFF; set to
# "1"/"true"/"on" to expose the flag-gated Live Teacher tab on inspections.
# The /turn route still enforces subscription + BYOK Anthropic key server-side.
NEXT_PUBLIC_LIVE_TEACHER=""

# NextAuth.js Authentication
NEXTAUTH_SECRET="your-32-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Next.js Server Actions (self-hosted / Digital Ocean)
# Set this so Server Action IDs stay stable across deploys and you avoid
# "Failed to find Server Action" after new deployments.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then set the same value in Digital Ocean App > Settings > Environment Variables.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# Google OAuth (for authentication)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Drive OAuth (setup-wizard BYOK storage — onboarding hotfix 2026-05-14)
# Required scopes: drive.file + drive.appdata + openid + email.
# Optional — if unset, the routes at /api/oauth/google-drive/* fall back to
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET above. In that case you must add
# ${NEXTAUTH_URL}/api/oauth/google-drive/callback as an authorised redirect
# URI on the existing OAuth client. In production prefer a dedicated client
# so the Drive consent screen doesn't show up during normal sign-in.
GOOGLE_DRIVE_CLIENT_ID="your-google-drive-client-id.apps.googleusercontent.com"
GOOGLE_DRIVE_CLIENT_SECRET="your-google-drive-client-secret"

# RA-2076 (1.0.4) — Google iOS-type OAuth client. Native iOS sign-in
# (via @capgo/capacitor-social-login) uses an iOS-type client, NOT the
# web client above. Audience claim of the inbound idToken is verified
# against this value in app/api/auth/native-token-exchange/route.ts.
# Per Google docs the client ID is not a secret, but we keep it in env
# so it can be rotated without a code push.
# Reversed-client-ID URL scheme lives in ios/App/App/Info.plist.
GOOGLE_IOS_CLIENT_ID="your-google-ios-client-id.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID="your-google-ios-client-id.apps.googleusercontent.com"

# Firebase (Google OAuth via Firebase Authentication)
# Required for the Google Sign-In button on the login page.
# Create a Firebase project at https://console.firebase.google.com, enable Google auth,
# then copy the Web SDK config values below.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""   # Optional — only needed if using Analytics

# Firebase Admin SDK (server-side Firebase token verification in /api/auth/google-signin)
# In Firebase Console → Project Settings → Service Accounts → Generate new private key.
# Paste the entire JSON as a single-line string (minified).
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Google Drive Picker (Claims Analysis - browse user's Drive)
# App ID = Google Cloud project number (numeric). API key from Cloud Console > Credentials.
NEXT_PUBLIC_GOOGLE_APP_ID=""
NEXT_PUBLIC_GOOGLE_API_KEY=""

# Google service account — server-side Drive access (lib/google-drive.ts,
# app/api/claims/list-files/route.ts). Distinct from the OAuth client above and
# from FIREBASE_SERVICE_ACCOUNT_KEY: these are the three discrete fields of a
# Cloud service-account JSON key. OPTIONAL — required only for the service-account
# Drive flow (server reads files from a folder shared with GOOGLE_CLIENT_EMAIL).
# GOOGLE_PRIVATE_KEY must keep literal \n escapes; code converts them at runtime.
GOOGLE_PROJECT_ID="your-gcp-project-id"
GOOGLE_CLIENT_EMAIL="service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key-here\n-----END PRIVATE KEY-----\n"

# ============================================
# REQUIRED - Payment Processing
# ============================================

# Stripe (payment processing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — tier checkout (app/api/billing/checkout/route.ts).
# Each maps a subscription tier to its Stripe recurring Price ID. Checkout
# throws "Missing STRIPE_PRICE_<TIER>" if the matching one is unset.
STRIPE_PRICE_STANDARD="price_..."
STRIPE_PRICE_PREMIUM="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# Stripe Price IDs — Free→Pro monthly/yearly plans (lib/pricing.ts).
# If unset, pricing falls back to placeholder strings ("MONTHLY_PLAN"/
# "YEARLY_PLAN") which are NOT valid Stripe Price IDs — set these in any
# environment where real checkout is expected.
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_YEARLY="price_..."

# ============================================
# ============================================
# OPTIONAL - AI Providers (at least one required for features)
# ============================================

# Anthropic Claude (AI chat, analysis)
ANTHROPIC_API_KEY="sk-ant-..."

# Google Generative AI (alternative AI provider)
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-key"

# OpenAI (alternative AI provider)
OPENAI_API_KEY="sk-..."

# Deepseek (alternative AI provider)
DEEPSEEK_API_KEY="sk-..."

# Google Gemini — Margot assistant only (app/api/margot/chat/route.ts deep_research
# tool + lib/margot-image-gen.ts). Distinct from GOOGLE_GENERATIVE_AI_API_KEY above.
# OPTIONAL — if unset, Margot's deep_research and image generation return a
# "GEMINI_API_KEY not configured" error; the rest of the app is unaffected.
GEMINI_API_KEY="your-gemini-api-key"

# Ollama — local LLM endpoint for the Scout + Brand Ambassador crons
# (lib/cron/scout-agent.ts, lib/cron/brand-ambassador.ts).
# OPTIONAL — both default in code if unset (base URL http://localhost:11434/v1,
# model gemma4:latest), so only set these to point at a non-default Ollama host.
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="gemma4:latest"

# ============================================
# OPTIONAL - Email Service
# ============================================

# Resend (transactional emails)
RESEND_API_KEY="re_..."
# Verified sender for all outbound email (lib/email.ts, lib/cron/process-emails.ts).
# If unset, code falls back to Resend's shared sandbox sender
# "Restore Assist <onboarding@resend.dev>", which only delivers to the
# account owner — set a verified domain sender for real recipients.
RESEND_FROM_EMAIL="Restore Assist <noreply@restoreassist.app>"

# ============================================
# OPTIONAL - File Storage
# ============================================

# Cloudinary (image/file storage, PDFs, documents)
# Used for: Business logos, inspection photos, Excel reports, invoice PDFs, report PDFs, attachments
# Features: Auto-optimization, CDN delivery, signed URLs, automatic cleanup via tags/TTL
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# AWS S3 (alternative file storage)
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="ap-southeast-2"
AWS_S3_BUCKET="restoreassist-uploads"

# ============================================
# OPTIONAL - External Integrations (V2 features)
# ============================================

# Xero OAuth 2.0
XERO_CLIENT_ID="your-xero-client-id"
XERO_CLIENT_SECRET="your-xero-client-secret"
XERO_WEBHOOK_KEY="your-xero-webhook-signing-key"
# Xero account routing (Xero account codes for invoice categorisation)
XERO_ACCOUNT_WATER="200"
XERO_ACCOUNT_FIRE="201"
XERO_ACCOUNT_MOULD="202"
XERO_ACCOUNT_STORM="203"
XERO_ACCOUNT_BIOHAZARD="204"
XERO_ACCOUNT_CONTENTS="205"

# QuickBooks OAuth 2.0
QUICKBOOKS_CLIENT_ID="your-quickbooks-client-id"
QUICKBOOKS_CLIENT_SECRET="your-quickbooks-client-secret"
QUICKBOOKS_WEBHOOK_TOKEN="your-quickbooks-webhook-verification-token"

# MYOB OAuth 2.0
MYOB_CLIENT_ID="your-myob-client-id"
MYOB_CLIENT_SECRET="your-myob-client-secret"
MYOB_WEBHOOK_SECRET="your-myob-webhook-secret"
# MYOB account routing (default chart-of-accounts codes)
MYOB_ACCOUNT_WATER="4-1100"
MYOB_ACCOUNT_FIRE="4-1200"
MYOB_ACCOUNT_MOULD="4-1300"

# ServiceM8 OAuth 2.0
SERVICEM8_CLIENT_ID="your-servicem8-client-id"
SERVICEM8_CLIENT_SECRET="your-servicem8-client-secret"
SERVICEM8_WEBHOOK_SECRET="your-servicem8-webhook-secret"
# ServiceM8 webhook URL to register: https://restoreassist.com.au/api/webhooks/servicem8

# Ascora API
ASCORA_API_KEY="your-ascora-api-key"
ASCORA_API_SECRET="your-ascora-api-secret"
# Account the system-level (cron) sync attaches jobs to when no user has
# connected Ascora in-app yet — exact email of an existing user.
ASCORA_SYNC_USER_EMAIL="owner@example.com"
# Ascora job type mapping (display names for damage types in Ascora)
ASCORA_JOB_TYPE_WATER="Water Damage"
ASCORA_JOB_TYPE_FIRE="Fire Damage"
ASCORA_JOB_TYPE_MOULD="Mould Remediation"

# Integration token encryption (32 bytes hex = 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=""

# Credential vault encryption key (lib/credential-vault.ts AES-256-GCM).
# OPTIONAL — getDefaultKey() falls back to INTEGRATION_ENCRYPTION_KEY, then
# NEXTAUTH_SECRET, so it is only required if you want a vault key independent of
# those. NOTE: tokens encrypted with one key cannot be decrypted with another —
# don't change it once integrations have stored tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=""

# ============================================
# OPTIONAL - Insurer Carrier Intake (Progress Framework stabilisation packets)
# ============================================
# Per-carrier intake endpoints. lib/progress/integrations/stabilisation-packet.ts
# reads process.env[<VAR>] per carrier; submitToCarrier() returns
# "carrier endpoint not configured" (a no-op) when the matching one is unset.
# OPTIONAL — leave blank unless you have a live/sandbox carrier intake URL.
GUIDEWIRE_SANDBOX_URL=""
YOUI_API_URL=""
HOLLARD_API_URL=""

# Australian Business Register (ABN lookup) — lib/integrations/abr/client.ts.
# ABR_API_GUID is the registered GUID for the ABR JSON web service.
# REQUIRED for ABN lookups: without it lookupAbn() returns MALFORMED for every
# ABN. ABR_BASE_URL is OPTIONAL (defaults to https://abr.business.gov.au/json/).
# Register a GUID at https://abr.business.gov.au/Tools/WebServices
ABR_API_GUID="your-abr-web-services-guid"
ABR_BASE_URL="https://abr.business.gov.au/json/"

# Property data scraper service (app/api/properties/scrape/health/route.ts).
# OPTIONAL — when unset the scrape health endpoint reports the integration as
# not configured; property auto-fill from the scraper is unavailable.
PROPERTY_SCRAPER_URL=""
# OPTIONAL — set to "1" to make the scrape health endpoint report 503 degraded
# when PROPERTY_SCRAPER_URL is unset (strict mode for deployments that require
# the scraper). Any other value: health reports ok without the URL.
PROPERTY_SCRAPER_REQUIRED=""

# ============================================
# OPTIONAL - Analytics (PostHog)
# ============================================
# Server-side event capture in lib/analytics/track.ts. If POSTHOG_API_KEY is
# unset, PostHog capture is skipped (DB analytics still record). POSTHOG_HOST is
# OPTIONAL (defaults to https://app.posthog.com; set for EU/self-hosted).
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ============================================
# AI — Self-Hosted Gemma-4-31B-IT (RA-403)
# ============================================
# NOTE (RA-6947): two separate code paths read two separate env-var pairs for
# this tier — set BOTH to the same OpenAI-compatible endpoint, or neither.

# Read by lib/ai/gemma-client.ts, used by model-router.ts's routeBasic()
# (setup-wizard basic-tier path).
# Self-hosted Gemma-4-31B-IT endpoint (OpenAI-compatible chat completions API)
# Deploy on A10G GPU (~$550/month via RunPod/Lambda Labs/CoreWeave).
# Handles basic+standard AI tasks (evidence classification, note structuring,
# photo scoring) — 60-80% cost reduction vs routing everything through BYOK.
# If not set, all tasks fall back to the customer's BYOK provider.
GEMMA_ENDPOINT_URL=""         # e.g. https://your-gpu-host.runpod.io/v1
GEMMA_API_KEY=""              # optional — some inference servers require a key

# Read by lib/ai/restoreassist-ai-client.ts, used by model-router.ts's main
# routeAiRequest() basic tier and lib/ai/adjuster-agent.ts. This is the
# "RestoreAssist AI" tier surfaced in Settings → AI Providers.
# Point this at any OpenAI-compatible /v1 chat-completions provider
# (e.g. Together AI, DeepInfra, RunPod vLLM). If not set, falls back to
# https://ai.restoreassist.app/v1, which is not currently provisioned —
# every request silently falls back to the customer's BYOK key at 5-50x cost.
RESTOREASSIST_AI_ENDPOINT=""  # e.g. https://api.together.xyz/v1
RESTOREASSIST_AI_API_KEY=""
RESTOREASSIST_AI_MODEL=""     # optional — overrides the "gemma-4-31b-it" default to match the provider's model id

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable mock OAuth flows for development
INTEGRATION_DEV_MODE="false"

# Enable regulatory citations feature
ENABLE_REGULATORY_CITATIONS="false"

# Admin impersonation feature flag (app/api/admin/impersonate + /stop). The
# endpoints return 501 FEATURE_DISABLED unless this is exactly "true" — the
# token-mint path is built but runtime session-swap is pending security review
# (RA-1592). Dev/test only; leave "false" in production.
ENABLE_ADMIN_IMPERSONATION="false"

# ============================================
# APPLICATION URLs
# ============================================

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron Secret (Bearer token for external cron schedulers)
CRON_SECRET="your-cron-secret-here"

# Cron watchdog alert recipient (RA-7026). When any monitored cron never
# succeeds, goes stale, or fails repeatedly, /api/cron/cron-watchdog emails
# this address. Unset = watchdog logs the problem but sends no email.
CRON_ALERT_EMAIL="ops@example.com"

# Smoke-prod BotID bypass secret (RA-4987)
# Lets smoke-prod.yml (GitHub Actions egress IPs, flagged as bots by Vercel
# BotID) run @smoke against https://restoreassist.app. verifyBotId() timing-safe
# compares the x-smoke-test-token header against this value. Fail-closed: unset
# means NO bypass path. Set the SAME value in Vercel prod env AND the GitHub
# Actions secret. Generate with: openssl rand -hex 32
SMOKE_TEST_BOT_BYPASS_SECRET="your-smoke-bypass-secret-here"

# Connections status manifest token (RA-6937)
# Bearer token for /api/v1/connections/status — the Mission Control / Hermes
# readiness poller. Generate with: openssl rand -hex 32
# Must be set in Vercel prod and shared with the Mission Control consumer.
CONNECTIONS_STATUS_TOKEN="your-connections-status-token-here"

# GitHub Webhook Secret (for /api/webhooks/github — sandbox → main release notes)
# Generate with: openssl rand -hex 32
# Set the same value in GitHub repo Settings → Webhooks
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret-here"

# Linear API Key (for Scout Agent — creates intelligence issues in Linear)
# Create at: https://linear.app/settings/api → Personal API keys
LINEAR_API_KEY="lin_api_..."
# Optional overrides (defaults to hardcoded RA team UUIDs from 2026-04 setup)
LINEAR_RA_TEAM_ID=""
LINEAR_SCOUT_LABEL_ID=""
LINEAR_RA_TODO_STATE_ID=""

# ============================================
# NEXUS HUB / HERMES (Margot health + Mission Control)
# ============================================
# Local Hermes dashboard (Nexus Hub operator — not owned by RestoreAssist)
HERMES_BASE_URL="http://127.0.0.1:9119"
# Optional browser link for /dashboard/mission-control
NEXT_PUBLIC_HERMES_OPS_URL="http://127.0.0.1:9119/ops"
# Inject Nexus Hub brand/wiki/memory into Margot chat (explicit opt-in; keep 0 unless Board/Pi-approved for the environment)
MARGOT_NEXUS_CONTEXT=0

# Telegram (optional — CEO board meeting summary delivery)
# Create a bot at t.me/BotFather, add to your personal chat or channel
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ============================================
# NIR PILOT PROGRAM (Phase 2)
# ============================================

# Shared token for the adjuster self-report form at /pilot/adjuster-review
# Issued to each participating insurer team. Rotate between pilot rounds.
# Usage: https://app.restoreassist.com.au/pilot/adjuster-review?token=<value>
PILOT_ADJUSTER_TOKEN="nir-pilot-2026"

# ============================================
# CONTENT PIPELINE — Video Production
# ============================================

# ============================================
# Synthex Service Proxy (RECOMMENDED)
# ============================================
# RestoreAssist proxies avatar/voice generation to Synthex, which holds
# the canonical HeyGen + ElevenLabs credentials and CEO voice clone.
# This avoids duplicating API keys across products.
#
# Synthex base URL (no trailing slash)
SYNTHEX_BASE_URL="https://synthex.social"
# Shared service token for cross-product auth (rotate quarterly)
# Generate with: openssl rand -hex 32
SYNTHEX_SERVICE_TOKEN=""

# ============================================
# ElevenLabs Voice, SFX & Music API (DIRECT — optional)
# ============================================
# Only needed if NOT using Synthex proxy, or for SFX generation
# (Synthex does not currently proxy sound effects).
# Create an account at https://elevenlabs.io
# Generate an API key under Profile → API Keys
#
# Plan: Creator ($11/mo) recommended for commercial content
#
# RESTOREASSIST VOICE LIBRARY:
# ┌───────────────┬──────────────────┬──────────────────────────────┐
# │ Role          │ Voice ID         │                              │
# ├───────────────┼──────────────────┼──────────────────────────────┤
# │ CEO Clone     │ aGkVQvWUZi16EH8a │ Primary (via Synthex)        │
# │ Luca          │ onwK4e9ZLuTAKqWW │ Fallback calm explainer      │
# │ Adam          │ pNInz6obpgDQGcF  │ Casual walkthrough           │
# │ Antoni        │ t3y2T6wYRVcp5Ww  │ Warm onboarding              │
# │ Josh          │ TxGEqnHWrfWFTfGW │ Authoritative compliance     │
# └───────────────┴──────────────────┴──────────────────────────────┘
#
# Voice settings (brand defaults in lib/synthex/client.ts):
#   Model: eleven_multilingual_v2
#   Stability: 0.55  (natural cadence)
#   Similarity boost: 0.80  (lip-sync fidelity)
#   Style: 0.25  (controlled expressiveness)
#
# SFX prompts (lib/elevenlabs/client.ts):
#   AMBIENCE_WARM — intro/outro beds (3s)
#   WHOOSH_TRANSITION — page transitions (0.5s)
#   POP_NOTIFICATION — UI interactions (0.8s)
#   IMPACT_LOW — emphasis moments (1s)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="jSuBIjxMKhqIfb0wCK1F"

# ============================================
# HeyGen LiveAvatar — AI Avatar & Video Generation (DIRECT — optional)
# ============================================
# Only needed if NOT using Synthex proxy for avatar video.
# Create an account at https://www.heygen.com
# Generate an API key under API Access → API Key
#
# Plan: Starter ($24/mo) minimum for custom avatars
# Custom avatar creation: 2 minutes of footage → upload in HeyGen dashboard
#
# RESTOREASSIST BRAND CONFIG:
#   - Avatar: Phill McGurk custom avatar (upload your 2 min footage)
#   - Voice: ElevenLabs CEO clone via Synthex (calm, warm, authoritative)
#   - Background: #1C2E47 (RestoreAssist navy)
#   - Video dimensions: 1920x1080 (landscape) or 1080x1920 (portrait mobile)
#
# Production checklist:
#   [ ] Upload 2 min footage to HeyGen → create avatar_id
#   [ ] Test generate-video with script under 5000 chars
#   [ ] Verify .mp4 output renders in AvatarOrb component
#   [ ] Set webhook for render-complete notifications (optional)
HEYGEN_API_KEY=""
HEYGEN_AVATAR_ID=""          # Required: your custom avatar ID from HeyGen dashboard
HEYGEN_WEBHOOK_SECRET=""     # Optional: webhook signature validation

# HeyGen token / CDN (populated by build scripts — DO NOT EDIT MANUALLY)
HEYGEN_GREETING_VIDEO_URL=""   # Runtime: landing-page orb greeting .mp4
HEYGEN_EXPLAINER_VIDEO_URL=""  # Runtime: product explainer .mp4

# ============================================
# CONTENT PIPELINE — YouTube Distribution
# ============================================

# YouTube Data API v3 (Google Cloud Console)
YOUTUBE_API_KEY=""            # API key for read-only analytics
YOUTUBE_CHANNEL_ID=""         # Target channel (UC...)

# YouTube OAuth client for video upload/management (lib/youtube/auth.ts).
# OPTIONAL — both fall back to GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET if unset.
# Set a dedicated YouTube client when you don't want to reuse the sign-in client.
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

# System user ID for automation (run: npx ts-node scripts/create-system-user.ts)
CONTENT_SYSTEM_USER_ID=""

# ============================================
# COMPANY / BRAND
# ============================================

# Company ABN (displayed in footer and compliance docs)
NEXT_PUBLIC_COMPANY_ABN="62 580 077 456"

# ============================================
# PORTAL SECURITY
# ============================================

# HMAC secret for signing portal tokens (insurer share links, client portal)
# Generate with: openssl rand -hex 32
PORTAL_SECRET=""

# ============================================
# APP STORE PUBLISHING
# ============================================

# Google Play service account (JSON key for Android Publisher API)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# App Store Connect API key (for iOS TestFlight + production submission)
ASC_API_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY_BASE64=

# Apple Developer team ID (10-char alphanumeric, e.g. ABCDE12345)
APPLE_TEAM_ID=

# Sign in with Apple — NextAuth provider config (RA-1842)
# `lib/auth.ts` registers AppleProvider only when both vars are set, so dev
# and preview deploys without the Apple Developer config don't crash.
#
# APPLE_CLIENT_ID is the Service ID configured in Apple Developer ("Identifier"
# under Services, e.g. com.example.web). It is NOT the App Bundle ID.
APPLE_CLIENT_ID=

# APPLE_CLIENT_SECRET is a JWT signed with the .p8 private key tied to
# APPLE_TEAM_ID + the Service ID's Key ID. Apple expires this JWT — typical
# rotation is every 6 months. See docs/IOS_SIGN_IN_WITH_APPLE.md for the
# generation/rotation runbook. Format: a string starting with `eyJ...`.
APPLE_CLIENT_SECRET=

# NEXT_PUBLIC_APPLE_SIGNIN_ENABLED controls whether the "Continue with Apple"
# button renders ON THE WEB (and SSR). Set to "true" once APPLE_CLIENT_ID +
# APPLE_CLIENT_SECRET above are configured. The iOS Capacitor shell ignores
# this flag — Sign in with Apple is always shown inside the iOS app because
# the native @capgo/capacitor-social-login plugin verifies the identity JWT
# via Apple's JWKS directly (no Service ID or .p8 secret needed). Apple App
# Review guideline 4.8 requires this button as a peer option to Google.
NEXT_PUBLIC_APPLE_SIGNIN_ENABLED=false
# trigger deploy Tue  2 Jun 2026 09:41:23 AEST

# ─────────────────────────────────────────────────────────────────────────────
# Read by code but previously undocumented (added 2026-06-15 env-hygiene audit).
# All OPTIONAL — features degrade/no-op when unset.
# ─────────────────────────────────────────────────────────────────────────────

# Cloudinary — combined URL form. Code reads CLOUDINARY_URL directly (the
# CLOUDINARY_CLOUD_NAME/_API_KEY/_API_SECRET trio documented above is the
# discrete form; set EITHER the URL or the trio).
CLOUDINARY_URL=

# Margot assistant internals (app/api/margot/*). Enable the tool surface and
# point at the file-search store id; unset = Margot tools off / no store.
MARGOT_TOOLS_ENABLED=false
MARGOT_FILE_SEARCH_STORE=

# Setup-wizard feature flag. "true" enables the onboarding setup wizard surface
# (sandbox/staging gate). Unset = off.
SETUP_WIZARD_ENABLED=false

# ============================================
# PREVIOUSLY-UNDOCUMENTED VARS (gap-audit remediation)
# Referenced by app/lib code but missing from this file — documenting them here
# prevents silent prod misconfiguration. Vercel/runtime-injected vars
# (VERCEL_ENV, VERCEL_URL, NODE_ENV, NEXT_PHASE) are intentionally omitted.
# ============================================

# Stripe publishable (client-side) key — REQUIRED for the checkout/billing UI.
# Safe to expose to the browser. Pair with STRIPE_SECRET_KEY (server) above.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OpenRouter BYOK (multi-provider AI). OPENROUTER_API_KEY is only a platform
# fallback — per-workspace keys live in Settings → AI Providers. OPENROUTER_MODEL
# is the default routing slug when a workspace/call doesn't specify one;
# OPENROUTER_SITE_URL is the optional HTTP-Referer attribution header.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=

# Accounting integration environments. "sandbox" or "production".
QUICKBOOKS_ENVIRONMENT=sandbox
MYOB_ENVIRONMENT=sandbox
# Ascora job-management API base URL (per-tenant deployments vary).
ASCORA_BASE_URL=

# Remote IICRC standards ingest (scripts/ingest-standards-remote.ts + the
# /api/cron/ingest-standards health probe). Bearer token gating the ingest
# route; the service-account folder id holding the standards PDFs.
STANDARDS_INGEST_TOKEN=
GOOGLE_DRIVE_STANDARDS_FOLDER_ID=

# Public contact addresses surfaced in the UI/footer.
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SECURITY_EMAIL=

# AI spend guardrail — default per-workspace daily budget in USD (soft cap).
AI_DEFAULT_DAILY_BUDGET_USD=

# Public invoice share links: number of days a public token stays valid.
INVOICE_PUBLIC_TOKEN_DAYS=

# USD→AUD conversion rate used for at-cost AI spend display (fallback constant).
RATE_USD_AUD=

# App version string shown in the UI (usually the release/commit tag).
NEXT_PUBLIC_APP_VERSION=

# --- E2E test helpers (app/api/test/*) — NEVER set on the real production app ---
# Two-key guard (see app/api/test/_helpers.ts testHelpersBlocked). The forging
# routes (sign-in-as, sign-in-google-as, seed-org-with-manager) run only when
# BOTH are satisfied. Local/CI: set ALLOW_TEST_HELPERS=true in .env.local.
# The restoreassist-sandbox Vercel project deploys as its OWN production target
# (VERCEL_ENV=production), so it must ALSO set ALLOW_TEST_HELPERS_IN_PROD_ENV=true
# to allow the helpers there. The real production app sets NEITHER.
ALLOW_TEST_HELPERS=
ALLOW_TEST_HELPERS_IN_PROD_ENV=
