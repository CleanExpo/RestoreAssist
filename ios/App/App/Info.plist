<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>RestoreAssist</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>RestoreAssist uses Bluetooth to read moisture meter data.</string>
	<key>NSCameraUsageDescription</key>
	<string>RestoreAssist uses your camera to photograph moisture meters, thermo-hygrometers, and laser measures so readings can be automatically extracted into your inspection report.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>RestoreAssist uses Face ID to protect your account when the app resumes.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>RestoreAssist uses your location to auto-fill the property address on new inspections.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>RestoreAssist saves inspection photos to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>RestoreAssist accesses your photo library to attach existing inspection photos to reports.</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!--
		1.0.4 (RA-2076): Google Sign-In URL scheme. The Google iOS OAuth
		client (RestoreAssist iOS, project=restoreassist) uses the
		reversed client ID as a URL scheme to receive its callback. This
		entry MUST match the iOS-type OAuth client registered in Google
		Cloud Console; if rotated, update both sides.

		Note: OAuth client IDs are public per Google's documented model
		(see https://developers.google.com/identity/sign-in/ios/start) —
		the bundle ID + iOS app signature anchor verifies caller
		identity, so this value can sit in source control safely.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.292141944467-8hhd4eub33tplq6ep5lc9iltu8jcatvp</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
