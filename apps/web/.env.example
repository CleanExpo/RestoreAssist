# RestoreAssist — apps/web Environment Variables
# Copy to .env.local and fill in values

# ============================================
# REQUIRED - Database
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/restoreassist"
DIRECT_URL="postgresql://user:password@localhost:5432/restoreassist"

# ============================================
# REQUIRED - Authentication (NextAuth.js)
# ============================================
NEXTAUTH_SECRET="your-32-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Drive Picker (Claims Analysis)
NEXT_PUBLIC_GOOGLE_APP_ID=""
NEXT_PUBLIC_GOOGLE_API_KEY=""

# ============================================
# REQUIRED - Payment Processing
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# OPTIONAL - AI Providers (at least one required)
# ============================================
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_GENERATIVE_AI_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""

# ============================================
# OPTIONAL - Email
# ============================================
RESEND_API_KEY="re_..."

# ============================================
# OPTIONAL - File Storage
# ============================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ============================================
# OPTIONAL - External Integrations (V2)
# ============================================
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
MYOB_CLIENT_ID=""
MYOB_CLIENT_SECRET=""
SERVICEM8_CLIENT_ID=""
SERVICEM8_CLIENT_SECRET=""
ASCORA_API_KEY=""
ASCORA_API_SECRET=""
INTEGRATION_ENCRYPTION_KEY=""

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET=""
