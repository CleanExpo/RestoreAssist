# Test DB environment for the setup-wizard work (and any future DB-touching test).
#
# COPY this file to .env.test.local and adjust values to match your setup.
# .env.test.local is gitignored and never committed.
#
# Recommended local setup:
#
#   docker run -d --name ra-setup-test-pg --rm -p 55432:5432 \
#     -e POSTGRES_PASSWORD=test \
#     -e POSTGRES_USER=postgres \
#     -e POSTGRES_DB=restoreassist_setup_test \
#     pgvector/pgvector:pg16
#
#   cd /path/to/worktree
#   set -a && source .env.test.local && set +a
#   npx prisma db push --skip-generate --accept-data-loss
#   npx vitest run scripts/__tests__/backfill-setup-wizard.test.ts
#
# Tear down: docker stop ra-setup-test-pg
#
# Use pgvector/pgvector:pg16 (NOT plain postgres:16) — the schema requires
# the pgvector extension for AI/embedding columns.

DATABASE_URL="postgres://postgres:test@localhost:55432/restoreassist_setup_test"
DIRECT_URL="postgres://postgres:test@localhost:55432/restoreassist_setup_test"

# Stub values to keep Phase 1+2 tests happy (no real network calls in unit tests).
SETUP_WIZARD_ENABLED="true"
ABR_API_GUID="00000000-0000-0000-0000-000000000000"
ABR_BASE_URL="https://abr.business.gov.au/json/"
