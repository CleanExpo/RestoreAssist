# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
package-lock.json

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
!.env*.example

# MCP config (contains API keys)
.mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo

# pilot-tester (sandbox harness — generated artefacts, not source)
/pilot-tester/images/cache/
/pilot-tester/reports/
/pilot-tester/user-pool.json
/pilot-tester/node_modules/
next-env.d.ts
/lib/generated/prisma

storybook-static/
nul

# Playwright E2E testing
/playwright-report/
/test-results/
.playwright/
# Auth state (contains credentials — never commit)
playwright/.auth/user.json

# MCP testing artifacts
.playwright-mcp/
dev-server.log
sketch-tab-test.png
v2-signin.png

.env*.local

# Root-level SQL scripts (development artefacts — migrations live in prisma/migrations/)
/*.sql

# Android signing keystores (NEVER commit)
*.jks
*.keystore
android/app/*.jks
android/app/*.keystore
android/keystore.properties
android/app/keystore.properties
.capacitor-native-notes/keystores/

# Git worktrees (Claude Code isolated workspaces)
.claude/worktrees/

# App Store / Google Play screenshot assets (generated by scripts/generate-store-assets.ts)
store-assets/


# Local Claude skills (may contain API keys)
.claude/skills/

# Session artifacts
commit_msg_*.txt
pr_body_*.txt
create_pr_*.bat
verify-settings.png
proxy.ts

# Local tooling
.omx/
.superpowers/
.hermes/

# Local secrets
secret.txt

# Multi-PC swarm — local identity per machine (see work-together.md)
.claude/swarm/identity.local.md
scripts/__pycache__/
.DS_Store
.claude/verifier-reports/
.claude/PROGRESS.md

# session-handoff Phase 0 gate logs (durable handoffs go in docs/session-handoffs/, tracked)
.handoff-logs/

# Build artefacts
public/help-index.json
release-gate-report.json

# RA-4985 — .codex/config.toml ships a real Composio API key when committed.
# Per `feedback_never_leak_secrets`, personal toolchain config must stay local.
.codex/
# Generated videos (do not commit to git — upload to Cloudinary instead)
videos/*.mp4
!videos/.gitkeep
# Remotion rendered videos — hosted on Cloudinary CDN
public/videos/remotion/*.mp4
remotion/output/*.mp4
logs/
